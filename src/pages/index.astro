---
import { getCollection } from "astro:content";
import CharacterCard from "../components/CharacterCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const characters = (await getCollection("characters")).sort((left, right) => left.data.order - right.data.order);
const tagOrder = ["Operative", "Mystic", "Outlaw", "Royal", "Synthetic", "Frontier", "Scholar"];
const tags = tagOrder.filter((tag) => characters.some((entry) => entry.data.tags.includes(tag)));
const featured = characters.slice(0, 3);
const basePath = import.meta.env.BASE_URL;
---

<BaseLayout
  title="AI Characters Showcase"
  description="A gallery-first Astro website for cinematic AI-generated character dossiers."
  pageClass="page-home"
>
  <section class="hero">
    <div class="hero__copy">
      <p class="eyebrow">Public Archive 01</p>
      <h1>AI-generated characters presented like classified legends, not stock gallery cards.</h1>
      <p class="hero__lede">
        Browse a curated dossier wall of operatives, royals, mystics, synthetics, and frontier ghosts. Each file opens into a dedicated profile page with lore, region data, and long-form field notes.
      </p>

      <div class="hero__actions">
        <a class="button button--primary" href="#signals">Browse dossiers</a>
        <a class="button button--secondary" href={`${basePath}characters/${featured[0].slug}/`}>
          Enter spotlight profile
        </a>
      </div>

      <dl class="hero__stats">
        <div>
          <dt>Active dossiers</dt>
          <dd>{characters.length}</dd>
        </div>
        <div>
          <dt>Signal tags</dt>
          <dd>{tags.length}</dd>
        </div>
        <div>
          <dt>Worlds indexed</dt>
          <dd>1</dd>
        </div>
      </dl>
    </div>

    <aside class="hero__panel">
      <p class="hero__panel-label">Spotlight transmission</p>
      <img
        class="hero__panel-image"
        src={`${basePath}${featured[0].data.heroImage.replace(/^\//, "")}`}
        alt={`${featured[0].data.name} spotlight art`}
      />
      <div class="hero__panel-body">
        <p class="hero__panel-role">{featured[0].data.role}</p>
        <h2>{featured[0].data.name}</h2>
        <p>{featured[0].data.shortDescription}</p>
        {featured[0].data.featuredQuote && <blockquote>{featured[0].data.featuredQuote}</blockquote>}
      </div>
    </aside>
  </section>

  <section class="section section--signals" id="signals">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Signal Filters</p>
        <h2>Browse the archive by archetype.</h2>
      </div>
      <p class="section-heading__text">
        V1 keeps the interaction deliberately light: tap a signal and the wall narrows to matching dossiers.
      </p>
    </div>

    <div class="filter-toolbar" data-filter-toolbar>
      <div class="filter-toolbar__buttons">
        <button type="button" class="filter-chip is-active" data-filter="All">All</button>
        {tags.map((tag) => (
          <button type="button" class="filter-chip" data-filter={tag}>
            {tag}
          </button>
        ))}
      </div>
      <p class="filter-toolbar__status" data-filter-status>
        Showing {characters.length} dossiers.
      </p>
    </div>

    <div class="gallery-grid" data-gallery>
      {characters.map((entry, index) => <CharacterCard entry={entry} featured={index === 0} />)}
    </div>
  </section>

  <section class="section section--notes" id="field-notes">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Field Notes</p>
        <h2>The archive is built for worldbuilding momentum.</h2>
      </div>
      <p class="section-heading__text">
        This first release is content-first: static deployment, structured dossiers, and room to expand into deeper timelines or process notes later.
      </p>
    </div>

    <div class="notes-grid">
      <article class="note-card">
        <h3>Structured for growth</h3>
        <p>Every character is stored as local content with a stable slug, typed metadata, and a long-form body.</p>
      </article>
      <article class="note-card">
        <h3>Pages over modals</h3>
        <p>Profiles have their own routes so each dossier can carry biography, setting context, and future gallery images.</p>
      </article>
      <article class="note-card">
        <h3>Portable deployment</h3>
        <p>The full site ships as a static build that fits GitHub Pages cleanly without server dependencies.</p>
      </article>
    </div>
  </section>

  <script is:inline>
    const cards = Array.from(document.querySelectorAll("[data-card]"));
    const buttons = Array.from(document.querySelectorAll("[data-filter]"));
    const status = document.querySelector("[data-filter-status]");

    const updateView = (activeFilter) => {
      let visible = 0;

      cards.forEach((card) => {
        const cardTags = (card.getAttribute("data-tags") || "").split("|").filter(Boolean);
        const matches = activeFilter === "All" || cardTags.includes(activeFilter);

        card.toggleAttribute("hidden", !matches);

        if (matches) {
          visible += 1;
        }
      });

      buttons.forEach((button) => {
        button.classList.toggle("is-active", button.getAttribute("data-filter") === activeFilter);
      });

      if (status) {
        const suffix = visible === 1 ? "" : "s";
        status.textContent =
          activeFilter === "All"
            ? `Showing ${visible} dossier${suffix}.`
            : `Showing ${visible} ${activeFilter.toLowerCase()} dossier${suffix}.`;
      }
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        updateView(button.getAttribute("data-filter") || "All");
      });
    });
  </script>
</BaseLayout>
