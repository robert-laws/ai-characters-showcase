---
import BaseLayout from "../layouts/BaseLayout.astro";
import MediaPlaceholder from "../components/MediaPlaceholder.astro";
import { homeCatalog } from "../data/characterCatalog";

const heroFeature = homeCatalog.hero;
const selections = homeCatalog.selections;
const latestDrops = homeCatalog.newArchive;
const highlight = homeCatalog.highlight;
const verticalFeature = homeCatalog.verticalFeature;
const footerLandscape = homeCatalog.footerLandscape;
const categories = homeCatalog.categoryTiles;
const getPlaceholderImagePath = (entry, placeholder) =>
  entry.images.find((image) => image.placeholder === placeholder)?.src ?? entry.primaryImage.src;
const selectionLabel = (entry) => `${entry.name} / Character edition`;
const categoryLabel = (category) => `${category.category} / Signal collection`;
const archiveLabel = (entry) => `${entry.name} / Archive arrival`;
const formatSignal = (value) =>
  value
    .replace(/-/g, " ")
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
const heroSignals = [heroFeature.category, heroFeature.species, ...heroFeature.tags.slice(0, 2).map(formatSignal)];
const testimonials = [
  {
    title: "Collector Notes",
    quote: "The catalog structure makes every character feel like part of a premium release instead of a loose gallery upload."
  },
  {
    title: "Art Direction",
    quote: "The numbered placeholder approach is perfect for iterating on imagery later without losing layout momentum."
  },
  {
    title: "Worldbuilding",
    quote: "This format gives the archive enough commerce-style rhythm to feel polished while still serving story and lore."
  }
];
const basePath = import.meta.env.BASE_URL;
const heroInsetSrc = `${basePath}images/layout-samples/21-auric-vale-supporting-inset.jpg`;
const heroShelfNote = `${heroFeature.name} anchors the current release with a tighter field-file portrait, a sharper read on the lead dossier, and a cleaner bridge into the archive.`;
---

<BaseLayout
  title="AI Characters Showcase"
  description="A gallery-first Astro website for cinematic AI-generated character dossiers."
  pageClass="page-home page-home--catalog"
>
  <section class="catalog-hero">
    <div class="catalog-hero__media">
      <MediaPlaceholder
        number="01"
        label={`${heroFeature.name} / Lead feature`}
        aspect="hero"
        tone="cool"
        src={`${basePath}${heroFeature.primaryImage.src.replace(/^\//, "")}`}
        alt={`${heroFeature.name} sample hero image`}
      />
      <div class="catalog-hero__shelf">
        <div class="catalog-hero__inset">
          <img src={heroInsetSrc} alt={`${heroFeature.name} supporting inset portrait`} loading="lazy" />
        </div>
        <div class="catalog-hero__shelf-copy">
          <p class="catalog-label">Archive note</p>
          <p>{heroShelfNote}</p>
        </div>
        <div class="catalog-hero__signals" aria-label={`${heroFeature.name} signal tags`}>
          {heroSignals.map((signal) => (
            <span class="catalog-signal">{signal}</span>
          ))}
        </div>
        <a class="catalog-hero__shelf-link" href={`${basePath}characters/${heroFeature.slug}/`}>
          Read field notes
        </a>
      </div>
    </div>
    <div class="catalog-hero__copy">
      <p class="catalog-kicker">Seasonal Character Edit</p>
      <div class="catalog-hero__headline">
        <p class="catalog-brand">AI Characters Showcase</p>
        <h1>Curated character releases, world files, and visual dossiers in one archive.</h1>
        <p>
          Explore cinematic character profiles as if each one arrived in a seasonal drop: featured portraits, category-led browsing, and dedicated files built for lore, attributes, and visual identity.
        </p>
      </div>

      <div class="catalog-hero__meta">
        <div>
          <p class="catalog-label">Lead feature</p>
          <h2>{heroFeature.name}</h2>
          <p>{heroFeature.category} / {heroFeature.species}</p>
        </div>
        <a class="button button--primary" href={`${basePath}characters/${heroFeature.slug}/`}>
          Open lead dossier
        </a>
      </div>
    </div>
  </section>

  <section class="catalog-section">
    <div class="catalog-section__heading">
      <div>
        <p class="catalog-kicker">Current Release</p>
        <h2>Spring file selections</h2>
      </div>
      <p>
        A front-row edit of the current lead characters, presented as collectible releases with direct paths into their full dossiers.
      </p>
    </div>

    <div class="catalog-grid catalog-grid--five">
      {selections.map((entry, index) => (
        <article class="catalog-card">
          <a href={`${basePath}characters/${entry.slug}/`}>
            <MediaPlaceholder
              number={String(index + 2).padStart(2, "0")}
              label={selectionLabel(entry)}
              aspect="portrait"
              tone={index % 2 === 0 ? "dark" : "cool"}
              src={`${basePath}${getPlaceholderImagePath(entry, String(index + 2).padStart(2, "0")).replace(/^\//, "")}`}
              alt={`${entry.name} selection sample image`}
            />
            <div class="catalog-card__body">
              <p class="catalog-card__eyebrow">{entry.tags.map((tag) => tag.replace(/-/g, " ")).join(" / ")}</p>
              <h3>{entry.name}</h3>
              <p>{entry.category} / {entry.species}</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="catalog-section" id="signals">
    <div class="catalog-section__heading">
      <div>
        <p class="catalog-kicker">Browse By Signal</p>
        <h2>Browse the archive by signal</h2>
      </div>
      <p>Each signal groups the archive by archetype, giving the page a stronger browsing rhythm before you ever open an individual character file.</p>
    </div>

    <div class="category-grid">
      {categories.map((category, index) => (
        <article class="category-tile">
          <MediaPlaceholder
            number={category.placeholder}
            label={categoryLabel(category)}
            aspect="square"
            tone={index % 3 === 0 ? "warm" : "cool"}
            src={`${basePath}${category.image.src.replace(/^\//, "")}`}
            alt={`${category.category} category sample image`}
          />
          <div class="category-tile__body">
            <h3>{category.category}</h3>
            <p>{category.name}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="catalog-section">
    <div class="catalog-section__heading">
      <div>
        <p class="catalog-kicker">Recent Additions</p>
        <h2>New to the archive</h2>
      </div>
      <p>Fresh arrivals in the catalog, framed as recent additions so the archive can grow without losing its editorial structure.</p>
    </div>

    <div class="catalog-grid catalog-grid--five">
      {latestDrops.map((entry, index) => (
        <article class="catalog-card">
          <a href={`${basePath}characters/${entry.slug}/`}>
            <MediaPlaceholder
              number={String(index + 13).padStart(2, "0")}
              label={archiveLabel(entry)}
              aspect="portrait"
              tone={index % 2 === 0 ? "cool" : "warm"}
              src={`${basePath}${getPlaceholderImagePath(entry, String(index + 13).padStart(2, "0")).replace(/^\//, "")}`}
              alt={`${entry.name} new archive sample image`}
            />
            <div class="catalog-card__body">
              <p class="catalog-card__eyebrow">{entry.category}</p>
              <h3>{entry.name}</h3>
              <p>{entry.summary}</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="catalog-section catalog-section--testimonials">
    <div class="catalog-section__heading catalog-section__heading--centered">
      <div>
        <p class="catalog-kicker">Feedback Loop</p>
        <h2>Our visitors say</h2>
      </div>
    </div>

    <div class="testimonial-grid">
      {testimonials.map((testimonial) => (
        <article class="testimonial-card">
          <p class="testimonial-card__title">{testimonial.title}</p>
          <p>{testimonial.quote}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="editorial-band">
    <div class="editorial-band__copy">
      <p class="catalog-kicker">Campaign Feature</p>
      <h2>{highlight.name}, presented as a full-width campaign feature.</h2>
      <p>
        This section gives the archive a slower, more immersive beat between card rails: one character, one wide-format moment, and room for mood over metadata.
      </p>
    </div>
    <MediaPlaceholder
      number="18"
      label={`${highlight.name} / Editorial feature`}
      aspect="banner"
      tone="dark"
      src={`${basePath}${highlight.primaryImage.src.replace(/^\//, "")}`}
      alt={`${highlight.name} editorial banner image`}
    />
  </section>

  <section class="editorial-split" id="field-notes">
    <div class="editorial-split__copy">
      <p class="catalog-kicker">Field Notes</p>
      <h2>Every image-led moment still resolves into a deeper character file.</h2>
      <p>
        The visual language is more fashion-editorial than database, but the underlying goal stays the same: each character can support biography, powers, weaknesses, and world context without feeling flat.
      </p>
      <ul class="editorial-split__list">
        <li>Portrait-led slots can become anchored image essays for major characters.</li>
        <li>The metadata strips can evolve into editions, factions, or release collections later.</li>
        <li>Every card already routes into a dedicated JSON-backed character page.</li>
      </ul>
    </div>
    <MediaPlaceholder
      number="19"
      label={`${verticalFeature.name} / Portrait feature`}
      aspect="tall"
      tone="warm"
      src={`${basePath}${verticalFeature.primaryImage.src.replace(/^\//, "")}`}
      alt={`${verticalFeature.name} vertical feature image`}
    />
  </section>

  <section class="footer-feature">
    <MediaPlaceholder
      number="20"
      label="The Vale / Closing landscape"
      aspect="wide"
      tone="cool"
      src={`${basePath}${footerLandscape.src.replace(/^\//, "")}`}
      alt="Footer campaign landscape image"
    />
    <div class="footer-feature__copy">
      <p class="catalog-kicker">Closing Frame</p>
      <h2>A final landscape gives the archive a cinematic landing instead of a hard stop.</h2>
      <p>
        From here we can keep refining the voice, replace more sample imagery, and decide which sections should stay purely editorial versus become navigation for larger collections.
      </p>
    </div>
  </section>
</BaseLayout>
