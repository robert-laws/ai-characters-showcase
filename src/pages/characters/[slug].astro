---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { characters, getRelatedCharacters } from "../../data/characterCatalog";

export async function getStaticPaths() {
  return characters.map((character) => ({
    params: { slug: character.slug },
    props: {
      character,
      related: getRelatedCharacters(character)
    }
  }));
}

const { character, related } = Astro.props;
const basePath = import.meta.env.BASE_URL;

const appearanceEntries = Object.entries(character.appearance ?? {}).filter(([, value]) => Boolean(value));
const attributeEntries = Object.entries(character.attributes ?? {});
const secondaryImages = character.images.slice(1);
const labelize = (value: string) =>
  value
    .replace(/([a-z])([A-Z])/g, "$1 $2")
    .replace(/-/g, " ")
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
---

<BaseLayout
  title={`${character.name} | AI Characters Showcase`}
  description={character.summary}
  pageClass="page-dossier"
>
  <section class="dossier-hero">
    <div class="dossier-hero__poster">
      <img
        src={`${basePath}${character.primaryImage.src.replace(/^\//, "")}`}
        alt={`${character.name} character image`}
      />
    </div>

    <div class="dossier-hero__body">
      <p class="eyebrow">Character File / {character.slug}</p>
      <h1>{character.name}</h1>
      <p class="dossier-hero__role">{character.category} / {character.species}</p>
      <p class="dossier-hero__summary">{character.summary}</p>

      <dl class="dossier-grid">
        <div>
          <dt>Age</dt>
          <dd>{character.age}</dd>
        </div>
        <div>
          <dt>Gender</dt>
          <dd>{character.gender}</dd>
        </div>
        <div>
          <dt>Category</dt>
          <dd>{character.category}</dd>
        </div>
        <div>
          <dt>Tags</dt>
          <dd>{character.tags.join(" / ")}</dd>
        </div>
      </dl>

      <div class="dossier-hero__actions">
        <a class="button button--primary" href={basePath}>Back to archive</a>
      </div>
    </div>
  </section>

  {secondaryImages.length > 0 && (
    <section class="section dossier-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Image Set</p>
          <h2>Supporting visuals</h2>
        </div>
        <p class="section-heading__text">
          Additional sample imagery attached to this character from the JSON catalog.
        </p>
      </div>

      <div class="image-strip">
        {secondaryImages.map((image) => (
          <article class="image-strip__card">
            <img src={`${basePath}${image.src.replace(/^\//, "")}`} alt={`${character.name} ${image.type}`} loading="lazy" />
            <div>
              <p>{labelize(image.type)}</p>
              <h3>Placeholder {image.placeholder}</h3>
            </div>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="section dossier-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Profile</p>
        <h2>Appearance and identity</h2>
      </div>
      <p class="section-heading__text">
        The new detail pages are generated directly from the JSON metadata rather than the older markdown dossiers.
      </p>
    </div>

    <div class="profile-grid">
      <article class="prose-card">
        <h3>Backstory</h3>
        <p>{character.backstory}</p>
      </article>

      <article class="prose-card">
        <h3>Appearance</h3>
        <dl class="profile-facts">
          {appearanceEntries.map(([key, value]) => (
            <div>
              <dt>{labelize(key)}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>
      </article>
    </div>
  </section>

  {attributeEntries.length > 0 && (
    <section class="section dossier-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Attributes</p>
          <h2>Character profile metrics</h2>
        </div>
      </div>

      <div class="stat-grid">
        {attributeEntries.map(([key, value]) => (
          <article class="stat-card">
            <p>{labelize(key)}</p>
            <strong>{value}</strong>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="section dossier-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Capabilities</p>
        <h2>Strengths, weaknesses, and abilities</h2>
      </div>
    </div>

    <div class="profile-grid profile-grid--three">
      <article class="prose-card list-card">
        <h3>Strengths</h3>
        <ul>
          {character.strengths.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="prose-card list-card">
        <h3>Weaknesses</h3>
        <ul>
          {character.weaknesses.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="prose-card list-card">
        <h3>Abilities</h3>
        <ul>
          {character.abilities.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  {related.length > 0 && (
    <section class="section dossier-section">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Related Files</p>
          <h2>Adjacent characters</h2>
        </div>
      </div>

      <div class="related-grid">
        {related.map((relatedCharacter) => (
          <a class="related-card" href={`${basePath}characters/${relatedCharacter.slug}/`}>
            <img
              src={`${basePath}${relatedCharacter.primaryImage.src.replace(/^\//, "")}`}
              alt={`${relatedCharacter.name} related image`}
              loading="lazy"
            />
            <div>
              <p>{relatedCharacter.category}</p>
              <h3>{relatedCharacter.name}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
