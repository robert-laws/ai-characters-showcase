---
import "../styles/global.css";

const {
  title = "AI Characters Showcase",
  description = "A cinematic archive of AI-generated character dossiers.",
  pageClass = ""
} = Astro.props;

const basePath = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
  </head>
  <body class={pageClass}>
    <div class="page-shell">
      <div class="page-shell__glow page-shell__glow--left"></div>
      <div class="page-shell__glow page-shell__glow--right"></div>

      <header class="site-header">
        <a class="site-header__brand" href={basePath}>
          <span class="site-header__mark">AI</span>
          <span class="site-header__title">Characters Showcase</span>
        </a>

        <nav class="site-nav" aria-label="Primary">
          <a href={basePath}>Archive</a>
          <a href={`${basePath}#signals`}>Signals</a>
          <a href={`${basePath}#field-notes`}>Field Notes</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__grid">
          <section class="site-footer__brand-block">
            <p class="site-footer__eyebrow">Archive Footer</p>
            <h2>AI Characters Showcase</h2>
            <p>
              A public-facing dossier archive for colorful AI character concepts, built as a static Astro site and deployed on GitHub Pages.
            </p>
          </section>

          <section class="site-footer__section">
            <p class="site-footer__label">Explore</p>
            <a href={basePath}>Archive Home</a>
            <a href={`${basePath}#signals`}>Signal Filters</a>
            <a href={`${basePath}#field-notes`}>Field Notes</a>
          </section>

          <section class="site-footer__section">
            <p class="site-footer__label">Project</p>
            <a href="https://robert-laws.github.io/ai-characters-showcase/">Live Site</a>
            <a href="https://github.com/robert-laws/ai-characters-showcase">GitHub Repository</a>
            <a href="https://github.com/robert-laws/ai-characters-showcase/actions/workflows/deploy.yml">Deployment Status</a>
          </section>
        </div>

        <div class="site-footer__bar">
          <p>&copy; {currentYear} AI Characters Showcase. Demo archive and visual concept site.</p>
          <p>Built with Astro and published via GitHub Pages.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
