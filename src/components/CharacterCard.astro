---
const { entry, featured = false } = Astro.props;
const { name, role, shortDescription, tags, heroImage, world, region } = entry.data;
const basePath = import.meta.env.BASE_URL;
---

<article
  class:list={["character-card", featured && "character-card--featured"]}
  data-card
  data-tags={tags.join("|")}
>
  <div class="character-card__poster">
    <img src={`${basePath}${heroImage.replace(/^\//, "")}`} alt={`${name} dossier art`} loading="lazy" />
  </div>

  <div class="character-card__body">
    <div class="character-card__meta">
      <p>{role}</p>
      {world && <span>{world}</span>}
      {region && <span>{region}</span>}
    </div>

    <h2>{name}</h2>
    <p class="character-card__summary">{shortDescription}</p>

    <ul class="character-card__tags" aria-label={`${name} tags`}>
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>

    <a class="character-card__link" href={`${basePath}characters/${entry.slug}/`}>
      Open dossier
    </a>
  </div>
</article>
