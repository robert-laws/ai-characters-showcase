---
const { number, label, aspect = "portrait", tone = "cool", src = null, alt = label } = Astro.props;
---

<div class:list={["media-placeholder", `media-placeholder--${aspect}`, `media-placeholder--${tone}`]}>
  {src && <img class="media-placeholder__image" src={src} alt={alt} loading="lazy" />}
  <span class="media-placeholder__number">{number}</span>
  <span class="media-placeholder__label">{label}</span>
</div>

<style>
  .media-placeholder {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: 100%;
    overflow: hidden;
    padding: 1rem;
    border: 1px dashed rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.02)),
      linear-gradient(180deg, rgba(2, 48, 71, 0.16), rgba(2, 48, 71, 0.02));
    isolation: isolate;
  }

  .media-placeholder__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
    z-index: -2;
  }

  .media-placeholder:has(.media-placeholder__image) {
    border-style: solid;
  }

  .media-placeholder:has(.media-placeholder__image)::before,
  .media-placeholder:has(.media-placeholder__image)::after {
    opacity: 0;
  }

  .media-placeholder:has(.media-placeholder__image)::before {
    inset: 0;
    width: auto;
    height: auto;
    right: 0;
    bottom: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, rgba(2, 48, 71, 0.04), rgba(2, 48, 71, 0.42));
    opacity: 1;
    z-index: -1;
  }

  .media-placeholder::before,
  .media-placeholder::after {
    content: "";
    position: absolute;
    inset: auto;
    border-radius: 999px;
    opacity: 0.55;
    z-index: -1;
  }

  .media-placeholder::before {
    width: 48%;
    height: 48%;
    right: -8%;
    bottom: -10%;
    background: rgba(255, 255, 255, 0.14);
  }

  .media-placeholder::after {
    width: 34%;
    height: 34%;
    left: 8%;
    top: 14%;
    background: rgba(255, 255, 255, 0.08);
  }

  .media-placeholder__number {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.7rem;
    min-height: 2.7rem;
    padding: 0.35rem;
    border-radius: 999px;
    background: rgba(2, 48, 71, 0.8);
    color: #f3fbff;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .media-placeholder__label {
    position: absolute;
    left: 0.9rem;
    right: 0.9rem;
    bottom: 0.9rem;
    display: inline-flex;
    width: fit-content;
    max-width: min(14rem, calc(100% - 1.8rem));
    padding: 0.45rem 0.7rem;
    border-radius: var(--radius-sm);
    background: rgba(2, 48, 71, 0.56);
    color: rgba(243, 251, 255, 0.9);
    font-family: var(--font-ui);
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  .media-placeholder--hero {
    aspect-ratio: 16 / 11;
  }

  .media-placeholder--portrait {
    aspect-ratio: 4 / 5;
  }

  .media-placeholder--square {
    aspect-ratio: 1 / 1;
  }

  .media-placeholder--wide {
    aspect-ratio: 16 / 9;
  }

  .media-placeholder--banner {
    aspect-ratio: 21 / 8;
  }

  .media-placeholder--tall {
    aspect-ratio: 3 / 4;
  }

  .media-placeholder--cool {
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.04)),
      linear-gradient(135deg, rgba(142, 202, 230, 0.5), rgba(33, 158, 188, 0.28));
  }

  .media-placeholder--warm {
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.04)),
      linear-gradient(135deg, rgba(255, 217, 120, 0.44), rgba(251, 133, 0, 0.28));
  }

  .media-placeholder--dark {
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
      linear-gradient(135deg, rgba(2, 48, 71, 0.88), rgba(13, 79, 107, 0.72));
  }

  .media-placeholder--hero .media-placeholder__label {
    max-width: 18rem;
  }
</style>
